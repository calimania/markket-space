---
import { getCollection } from "astro:content";
import PageLayout from "../../layouts/PageLayout.astro";
import BlocksContent from "../../components/BlocksContent.astro";
import { renderExcerpt, imgFor } from "../../lib/entry.utils";
import { IconShoppingBag, IconArrowRight, IconTag } from "@tabler/icons-react";

// Load store configuration and fallback metadata safely
const storeData = await getCollection("store");
const store = storeData[0]?.data || {};
const storeCover = store?.Cover || "";

const pages = await getCollection("pages");
const page = pages.find((p) => p.data.slug === "products")?.data;

const products = await getCollection("products");
// Filter to only display active items, capped at the collection limit
const productCards = products
  .filter((p) => (p.data as any)?.Active !== false)
  .slice(0, 24);

function productLinkFor(p: any) {
  const pd = p.data as any;
  if (pd?.ExternalUrl) return pd.ExternalUrl;
  const slug = pd?.slug || p.id;
  return `/products/${slug}`;
}

// Global Image Handling Fallback Pipeline
function imageOrFallback(
  ...candidates: Array<string | undefined | null>
): string {
  return (
    candidates.find(
      (item): item is string => typeof item === "string" && item.length > 0,
    ) || ""
  );
}

const heroImage = imageOrFallback(
  page?.SEO?.socialImage?.url,
  store?.SEO?.socialImage?.url,
  storeCover?.url,
);

const heroTitle = page?.Title || store?.SEO?.metaTitle || "Our Products";
const heroSubtitle =
  page?.SEO?.metaDescription ||
  store?.SEO?.metaDescription ||
  "Explore exclusive assets and creations.";
const heroLqip =
  (page?.SEO as any)?.socialImage?.formats?.small?.url ||
  (storeCover as any)?.formats?.small?.url ||
  "";
const heroAspect = (page?.SEO as any)?.meta?.heroAspect || "4/5";
const heroVariant = (page?.SEO as any)?.meta?.heroVariant || "spacious";
---

<PageLayout
  title={page?.SEO?.metaTitle || store?.SEO?.metaTitle || heroTitle}
  description={heroSubtitle}
  image={heroImage}
  heroTitle={heroTitle}
  heroSubtitle={heroSubtitle}
  heroImage={heroImage}
  heroLqip={heroLqip}
  heroAspect={heroAspect}
  heroVariant={heroVariant}
>
  <main class="products-directory">
    <!-- Products Showcase Grid -->
    <section class="products-grid-section">
      <div class="container">
        <div class="directory-header">
          <div class="title-cluster">
            <IconShoppingBag class="header-icon" size={24} />
            <h2>Catalog Showcase</h2>
          </div>
          <p class="count-indicator">{productCards.length} assets available</p>
        </div>

        {
          productCards && productCards.length > 0 ? (
            <div class="products-display-grid">
              {productCards.map((p: any) => {
                const displayTitle =
                  p.data?.Name || p.data?.Title || "Untitled Product";
                const price = (p.data as any)?.Price;
                const hasPrice =
                  typeof price === "number" || typeof price === "string";
                const isExternal = !!(p.data as any)?.ExternalUrl;

                return (
                  <a
                    href={productLinkFor(p)}
                    class="product-showcase-card"
                    aria-label={`View details for ${displayTitle}`}
                    target={isExternal ? "_blank" : undefined}
                    rel={isExternal ? "noopener noreferrer" : undefined}
                  >
                    <div class="product-media-wrapper">
                      {imgFor(p) ? (
                        <img
                          src={imgFor(p)}
                          alt={(p.data as any)?.SEO?.altText || displayTitle}
                          class="product-asset-img"
                          loading="lazy"
                        />
                      ) : (
                        <div class="product-media-placeholder">
                          <IconShoppingBag size={32} />
                        </div>
                      )}
                      {hasPrice && (
                        <div class="product-tag-bubble">
                          <IconTag size={14} />
                          <span>
                            {typeof price === "number" ? `$${price}` : price}
                          </span>
                        </div>
                      )}
                    </div>

                    <div class="product-meta-pane">
                      <div class="meta-headline-row">
                        <h3>{displayTitle}</h3>
                        <IconArrowRight className="action-arrow" size={16} />
                      </div>
                      <p class="product-snippet">
                        {(renderExcerpt(p) || "").slice(0, 110)}
                        {(renderExcerpt(p) || "").length > 110 ? "…" : ""}
                      </p>
                    </div>
                  </a>
                );
              })}
            </div>
          ) : (
            <div class="empty-catalog-fallback">
              <IconShoppingBag size={48} className="fallback-icon" />
              <h3>No Products Found</h3>
              <p>
                We are updating our store catalog. Check back shortly for new
                additions.
              </p>
            </div>
          )
        }
      </div>
    </section>

    <!-- Rich Text Block Content injected via dynamic CMS fields -->
    {
      page?.Content && page.Content.length > 0 && (
        <section class="page-content-section">
          <div class="container container-narrow">
            <BlocksContent content={page.Content} className="page-content" />
          </div>
        </section>
      )
    }
  </main>
</PageLayout>

<style>
  /* Base Architecture Layout setup */
  .products-directory {
    padding-bottom: 6rem;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .container-narrow {
    max-width: 860px;
  }

  /* Catalog Directory Layout Headers */
  .directory-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--border-light);
    padding-bottom: 1.25rem;
    gap: 1rem;
  }

  .title-cluster {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .header-icon {
    color: var(--primary);
  }

  .directory-header h2 {
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.025em;
    color: var(--text);
    margin: 0;
  }

  .count-indicator {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0;
    padding-bottom: 0.25rem;
  }

  /* Core 4:3 Aspect Catalog Presentation Grid */
  .products-display-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
  }

  /* Showcase Cards Layout styling */
  .product-showcase-card {
    display: flex;
    flex-direction: column;
    background: var(--bg);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg, 14px);
    overflow: hidden;
    text-decoration: none;
    box-shadow: var(--shadow, 0 2px 10px rgba(0, 0, 0, 0.03));
    transition:
      transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 0.25s cubic-bezier(0.4, 0, 0.2, 1),
      border-color 0.25s ease;
  }

  .product-showcase-card:hover {
    transform: translateY(-4px);
    border-color: var(--primary);
    box-shadow: var(--shadow-lg, 0 12px 28px rgba(0, 0, 0, 0.08));
  }

  /* Optimized 4:3 Ratio Media Block Containers */
  .product-media-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--bg-alt);
  }

  .product-asset-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.45s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .product-showcase-card:hover .product-asset-img {
    transform: scale(1.05);
  }

  .product-media-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(
      135deg,
      var(--bg-alt) 0%,
      var(--border-light) 100%
    );
    color: var(--text-muted);
  }

  /* Premium Floating Pricing Tags */
  .product-tag-bubble {
    position: absolute;
    bottom: 0.75rem;
    right: 0.75rem;
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: #fff;
    padding: 0.35rem 0.65rem;
    border-radius: var(--radius-sm, 6px);
    font-size: 0.825rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15);
    z-index: 2;
  }

  /* Meta Content Text Layers */
  .product-meta-pane {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .meta-headline-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .product-meta-pane h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.35;
    margin: 0;
    transition: color 0.2s ease;
  }

  .product-showcase-card:hover .product-meta-pane h3 {
    color: var(--primary);
  }

  .action-arrow {
    color: var(--text-muted);
    opacity: 0.4;
    transform: translateX(-2px);
    transition: all 0.2s ease;
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .product-showcase-card:hover .action-arrow {
    opacity: 1;
    color: var(--primary);
    transform: translateX(2px);
  }

  .product-snippet {
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--text-muted);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Secondary Structured Page Layout Blocks */
  .page-content-section {
    margin-top: 5rem;
    padding-top: 3rem;
    border-top: 1px solid var(--border-light);
  }

  /* Catalog Fallback Empty Placeholder Block styling */
  .empty-catalog-fallback {
    text-align: center;
    padding: 5rem 2rem;
    background: var(--bg-alt);
    border-radius: var(--radius-lg, 14px);
    border: 2px dashed var(--border-light);
    max-width: 500px;
    margin: 2rem auto 0;
  }

  .fallback-icon {
    color: var(--text-muted);
    opacity: 0.6;
    margin-bottom: 1rem;
  }

  .empty-catalog-fallback h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 0.5rem;
  }

  .empty-catalog-fallback p {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.5;
  }

  /* Media Queries and Mobile Layout optimizations */
  @media (max-width: 640px) {
    .directory-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
      margin-top: 2rem;
    }

    .products-display-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .product-meta-pane {
      padding: 1rem;
    }
  }
</style>
